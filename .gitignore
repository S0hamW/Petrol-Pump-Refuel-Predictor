# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
*.egg-info/

# ─────────────────────────────────────────────
# Jupyter — IMPORTANT
# ─────────────────────────────────────────────
# Checkpoint folders are auto-created by Jupyter
# They are duplicates of your notebooks — not needed
.ipynb_checkpoints/
*/.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ─────────────────────────────────────────────
# Large data files — do NOT push to GitHub
# Raw Excel and generated CSVs are too large
# ─────────────────────────────────────────────
data/*.xlsx
data/*.csv
data/*.pkl

# ─────────────────────────────────────────────
# Keep these files — push them to GitHub
# (override the rules above with !)
# ─────────────────────────────────────────────
!data/petrol_pump_2011_2025.xlsx
!data/selected_features.csv
!data/model_features.json
!data/model_metrics.json

# ─────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────
# Secrets — never push API keys
# ─────────────────────────────────────────────
.env
*.env
